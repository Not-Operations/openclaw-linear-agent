{
  "name": "openclaw-linear-agent",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "linear:health": "node --enable-source-maps dist/linear-health.js",
    "cli:auth-status": "node --enable-source-maps dist/cli/linear.js auth status",
    "test:smoke": "bash scripts/test-linear-setup.sh",
    "test:auth-status": "node tests/auth-status.test.mjs",
    "test:api-smoke": "bash tests/api-smoke.sh",
    "test:validation-smoke": "bash tests/validation-smoke.sh"
  },
  "bin": {
    "linear": "dist/cli/linear.js"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}

# Server
LINEAR_BRIDGE_PORT=3001
LOG_LEVEL=info

# OpenClaw CLI invocation
OPENCLAW_BIN=openclaw
OPENCLAW_LINEAR_AGENT_ID=project-manager
OPENCLAW_WORKDIR=/path/to/openclaw-workspace
OPENCLAW_TIMEOUT_SECONDS=180
OPENCLAW_THINKING=low

# Linear OAuth + webhook verification
LINEAR_APP_BASE_URL=https://your-bridge.example.com
LINEAR_REDIRECT_URI=https://your-bridge.example.com/auth/linear/callback
LINEAR_CLIENT_ID=replace_me
LINEAR_CLIENT_SECRET=replace_me
LINEAR_WEBHOOK_SECRET=replace_me
LINEAR_OAUTH_SCOPES=read,write,app:mentionable,app:assignable
LINEAR_STATE_SECRET=replace_me
LINEAR_TOKEN_STORE_PATH=~/.openclaw/state/linear-agent-bridge/tokens.json

# Behavior flags
POST_TO_LINEAR=false
ALLOW_AUTO_RUN=false

# Persistence
DATA_DIR=./data
